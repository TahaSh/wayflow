---
// –––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––
//  WayflowLogo — wordmark used in the header and drawer
// –––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––

interface Props {
  size?: number
}

const { size = 26 } = Astro.props
---

<a class="wf-logo" href="/" aria-label="Wayflow home">
  <svg
    viewBox="0 0 24 24"
    width={size}
    height={size}
    fill="none"
    aria-hidden="true"
  >
    <path
      d="M4 6C4 6 4.0001 15.3104 7.09979 17.7229C10.1995 20.1354 14.8491 6 10.9745 6C7.09983 6 9.42457 15.3104 13.2992 17.7229C15.683 19.2072 16.5643 10.9799 16.8275 7.4988C16.8902 6.66999 17.5981 6.03371 18.4282 6.07517L20 6.15367"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"></path>
  </svg>
  <span class="wm">Wayflow</span>
</a>
