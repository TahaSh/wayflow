---
// –––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––
//  SiteFooter — landing-page footer: brand + link columns + base line
// –––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––

import WayflowLogo from '@/components/chrome/WayflowLogo.astro'

const REPO_URL = 'https://github.com/TahaSh/wayflow'
const AUTHOR_URL = 'https://tahazsh.com/'
const NPM_URL = 'https://www.npmjs.com/package/wayflow'

const year = new Date().getFullYear()

const COLUMNS = [
  {
    title: 'Documentation',
    links: [
      { label: 'Quickstart', href: '/docs/getting-started/quickstart' },
      {
        label: 'Building workflows',
        href: '/docs/building-workflows/node-library',
      },
      {
        label: 'Running workflows',
        href: '/docs/running-workflows/overview',
      },
      { label: 'Mental model', href: '/docs/concepts/mental-model' },
    ],
  },
  {
    title: 'Project',
    links: [
      { label: 'GitHub', href: REPO_URL },
      { label: 'npm', href: NPM_URL },
      { label: 'License', href: `${REPO_URL}/blob/main/LICENSE` },
    ],
  },
]
---

<footer class="site-foot">
  <div class="site-foot__top">
    <div class="site-foot__brand">
      <WayflowLogo />
      <p class="site-foot__tag">
        An embeddable visual workflow editor for the web.
      </p>
      <a class="site-foot__gh" href={REPO_URL} aria-label="GitHub repository">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49 0-.24-.01-.88-.01-1.73-2.78.62-3.37-1.37-3.37-1.37-.46-1.18-1.11-1.49-1.11-1.49-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.37-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.7 0 0 .84-.27 2.75 1.05a9.4 9.4 0 0 1 5 0c1.91-1.32 2.75-1.05 2.75-1.05.55 1.4.2 2.44.1 2.7.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.06.36.32.68.94.68 1.9 0 1.37-.01 2.48-.01 2.82 0 .27.18.6.69.49A10.26 10.26 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z"></path></svg>
      </a>
    </div>

    <div class="site-foot__cols">
      {
        COLUMNS.map((col) => (
          <nav class="site-foot__col" aria-label={col.title}>
            <h4>{col.title}</h4>
            {col.links.map((link) => (
              <a href={link.href}>{link.label}</a>
            ))}
          </nav>
        ))
      }
    </div>
  </div>

  <div class="site-foot__base">
    <span>© {year} Wayflow · MIT licensed</span>
    <span>Built by <a href={AUTHOR_URL}>Taha Shashtari</a></span>
  </div>
</footer>
