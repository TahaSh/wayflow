---
// –––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––
//  Callout — note / tip / warning admonition
// –––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––––

const VARIANT = {
  note: {
    title: 'Note',
    icon: '<circle cx="12" cy="12" r="9"/><path d="M12 11v5M12 7.5v.5" stroke-linecap="round"/>',
  },
  tip: {
    title: 'Tip',
    icon: '<path d="M9 18h6M10 21h4M12 3a6 6 0 0 0-3.5 10.9c.5.4.5 1 .5 1.6h6c0-.6 0-1.2.5-1.6A6 6 0 0 0 12 3Z" stroke-linecap="round" stroke-linejoin="round"/>',
  },
  warn: {
    title: 'Heads up',
    icon: '<path d="M12 3 2.5 20h19L12 3Z" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 10v4M12 17v.5" stroke-linecap="round"/>',
  },
} as const

type Variant = keyof typeof VARIANT

interface Props {
  variant?: Variant
  title?: string
}

const { variant = 'note', title } = Astro.props
const tone = VARIANT[variant]
---

<div class:list={['callout', `callout--${variant}`]}>
  <span class="callout__icon">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" set:html={tone.icon}></svg>
  </span>
  <div class="callout__body">
    <p class="callout__title">{title ?? tone.title}</p>
    <slot />
  </div>
</div>
